PROJECT_NAME=ShopMind AI
VERSION=1.1.1
API_V1_STR=/api/v1
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-long-random-string
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Database
DATABASE_URL=
POSTGRES_USER=shopmind
POSTGRES_PASSWORD=shopmind
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=shopmind

# Redis / Celery
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
CELERY_TASK_ALWAYS_EAGER=True
CONVERSATION_STATE_BACKEND=redis
CONVERSATION_STATE_TTL_SECONDS=86400
AGENT_EVAL_MODE=baseline

# LLM / DashScope compatible OpenAI API
OPENAI_API_KEY=
OPENAI_MODEL_NAME=qwen3-max
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_TIMEOUT_SECONDS=8
LLM_MAX_RETRIES=2
LLM_CIRCUIT_BREAKER_THRESHOLD=3
LLM_CIRCUIT_BREAKER_RESET_SECONDS=30
DASHSCOPE_API_KEY=
EMBEDDING_MODEL_NAME=text-embedding-v4

# Vector Store
VECTOR_STORE_TYPE=chroma
ENABLE_VECTOR_RANKING=True
MILVUS_URI=
MILVUS_TOKEN=
MILVUS_HOST=localhost
MILVUS_PORT=19530
CHROMA_PERSIST_DIR=./chroma_db
